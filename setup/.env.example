# ==========================================
# LIBRECHAT CORE
# ==========================================
# The URL where LibreChat is deployed (used for OAuth callbacks)
LIBRECHAT_URL=https://your-domain.com

# Application title shown in the UI
APP_TITLE=Aurion AI

# Email login/registration settings
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false

# JWT secret for authentication (generate a strong random string)
JWT_SECRET=generate-a-strong-256-bit-random-string-here

# Encryption keys for credentials storage
CREDS_KEY=generate-a-32-byte-hex-string-here
CREDS_IV=generate-a-16-byte-hex-string-here

# ==========================================
# DATABASE
# ==========================================
# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/LibreChat

# MeiliSearch master key for search functionality
MEILI_MASTER_KEY=generate-a-strong-meilisearch-key-here

# ==========================================
# MCP OAUTH — GOOGLE SERVICES
# ==========================================
# NOTE: Gmail, Drive, and Calendar all use the SAME Google OAuth App
# You only need to create ONE Google Cloud Project and ONE OAuth 2.0 Client ID
#
# SETUP INSTRUCTIONS:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project or select an existing one
# 3. Enable APIs: "Gmail API", "Google Drive API", "Google Calendar API"
# 4. Go to "APIs & Services" → "Credentials"
# 5. Create "OAuth 2.0 Client ID" → Type: "Web application"
# 6. Add authorized redirect URIs:
#    - https://your-domain.com/api/mcp/gmail/oauth/callback
#    - https://your-domain.com/api/mcp/google-drive/oauth/callback
#    - https://your-domain.com/api/mcp/google-calendar/oauth/callback
# 7. Copy Client ID and Client Secret below
# 8. Configure OAuth consent screen (app name, logo, privacy policy)

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ==========================================
# MCP OAUTH — LINEAR
# ==========================================
# SETUP INSTRUCTIONS:
# 1. Go to https://linear.app → Settings → API → OAuth Applications
# 2. Create a new OAuth application
# 3. Set callback URL: https://your-domain.com/api/mcp/linear/oauth/callback
# 4. Copy Client ID and Client Secret below

LINEAR_CLIENT_ID=your-linear-client-id
LINEAR_CLIENT_SECRET=your-linear-client-secret

# ==========================================
# WEB SEARCH
# ==========================================
# Option 1: Tavily Search API (recommended, 1000 req/month free)
# Sign up at https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key

# Option 2: Firecrawl (for web scraping)
# Sign up at https://firecrawl.dev (free tier available)
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key

# Option 3: Brave Search API
# Sign up at https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key

# Option 4: Self-hosted SearXNG (alternative to Tavily)
# See docker-compose.override.yml for SearXNG setup
SEARXNG_URL=http://searxng:8080

# ==========================================
# CODE INTERPRETER
# ==========================================
# Option 1: LibreChat Code Interpreter API (paid service)
# Get your key at https://librechat.ai
CODE_INTERPRETER_API_KEY=lc-your-code-interpreter-key

# Option 2: E2B (free 100h/month, self-hostable)
# Sign up at https://e2b.dev
E2B_API_KEY=e2b-your-e2b-api-key

# ==========================================
# LLM PROVIDERS
# ==========================================
# Anthropic (Claude models)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# OpenAI (GPT models)
# Get your key at https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key

# OpenRouter (multi-provider access)
# Get your key at https://openrouter.ai
# Provides access to Anthropic, OpenAI, Google, Meta, DeepSeek, etc.
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# ==========================================
# EMAIL SERVICES (for email tools)
# ==========================================
# Resend API (for sending emails, 100/day free)
# Sign up at https://resend.com
RESEND_API_KEY=re-your-resend-api-key
EMAIL_FROM=Aurion <noreply@your-domain.com>

# IMAP (for reading emails)
# Configure for your email provider
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# ==========================================
# ARTIFACTS — Sandpack Bundler (optional)
# ==========================================
# For self-hosted Sandpack bundler (alternative to CodeSandbox)
# See docker-compose.override.yml for setup
SANDPACK_BUNDLER_URL=http://sandpack-bundler:4173

# ==========================================
# REDIS (for queue/caching)
# ==========================================
# Required for LibreChat production deployment
REDIS_URL=redis://localhost:6379

# ==========================================
# STORAGE (for file uploads)
# ==========================================
# Option 1: Local storage (default)
# No configuration needed - files stored locally

# Option 2: AWS S3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-s3-bucket-name

# Option 3: Firebase
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY=your-firebase-private-key
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ==========================================
# RATE LIMITING (optional)
# ==========================================
# Enable rate limiting for file uploads
RATE_LIMIT_FILE_UPLOADS=true
RATE_LIMIT_FILE_UPLOADS_IP_MAX=100
RATE_LIMIT_FILE_UPLOADS_IP_WINDOW_MINUTES=60
RATE_LIMIT_FILE_UPLOADS_USER_MAX=50
RATE_LIMIT_FILE_UPLOADS_USER_WINDOW_MINUTES=60

# ==========================================
# DEVELOPMENT / DEBUG
# ==========================================
# Enable debug logging
DEBUG=librechat:*

# Enable CORS for development
CORS_ORIGIN=*
